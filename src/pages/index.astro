---
import Layout from "../layouts/Layout.astro";
import site from "../content/site.json";

const {
  meta,
  navigation,
  hero,
  features,
  products,
  mobileHighlight,
  testimonials,
  subscribe,
  stickyCta,
  mascot,
  footer
} = site;
---

<Layout title={meta.title} description={meta.description} author={meta.author}>
  <header class="fixed inset-x-0 top-0 z-[1000] border-b border-black/5 bg-white/95 shadow-sm backdrop-blur-sm">
    <nav class="mx-auto flex w-full max-w-6xl flex-col items-start justify-between gap-3 px-5 py-4 md:flex-row md:items-center md:py-3">
      <div class="logo text-lg font-semibold tracking-wide text-brand-primary md:text-xl">{navigation.brand}</div>
      <ul class="nav-links flex list-none flex-wrap items-center gap-x-6 gap-y-2 text-sm font-medium">
        {navigation.items.map((item) => (
          <li><a class="transition-colors hover:text-brand-accent" href={item.href}>{item.label}</a></li>
        ))}
      </ul>
    </nav>
  </header>

  <section id="home" class="hero bg-brand-secondary text-brand-primary">
    <div class="mx-auto w-full max-w-6xl px-5">
      <div class="hero-content py-4 md:py-6">
        <div class="hero-text text-center">
          <h1 class="text-4xl font-bold leading-tight md:text-5xl">{hero.title}</h1>
          <p class="mx-auto max-w-2xl text-base md:text-lg">{hero.description}</p>
          <a
            href={hero.button.href}
            class="inline-block rounded-md bg-brand-primary px-6 py-3 text-sm font-semibold text-white shadow transition-all hover:translate-y-[-1px] hover:bg-brand-accent"
            >{hero.button.label}</a
          >
        </div>
      </div>
    </div>
  </section>

  <section id="features" class="features py-20">
    <div class="mx-auto w-full max-w-6xl px-5">
      <div class="section-header mx-auto mb-12 max-w-3xl text-center">
        <h2 class="text-lg font-semibold uppercase tracking-wide text-brand-accent">{features.eyebrow}</h2>
        <h2 class="text-3xl font-bold text-brand-primary">{features.title}</h2>
        <p class="text-[15px] text-slate-700">{features.description}</p>
      </div>
      <div class="features-grid grid gap-8 md:grid-cols-2">
        {features.items.map((item) => (
          <div>
            <div class="feature-card h-full rounded-lg bg-white p-8 text-center shadow-lg">
              <div class="feature-icon mb-4 text-4xl" set:html={item.icon}></div>
              <h3 class="text-xl font-semibold text-brand-primary">{item.title}</h3>
              <p class="mt-3 text-sm text-slate-700">{item.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section id="products" class="products py-20">
    <div class="mx-auto w-full max-w-6xl px-5">
      <div class="section-header mx-auto mb-12 max-w-3xl text-center">
        <h2 class="text-3xl font-bold text-brand-primary">{products.title}</h2>
        <p class="text-[15px] text-slate-700">{products.description}</p>
      </div>
      <div class="products-grid grid gap-8 md:grid-cols-2 lg:grid-cols-3">
        {products.items.map((item) => (
          <div>
            <div class="product-card h-full overflow-hidden rounded-lg bg-white shadow-lg">
              <div class="product-image flex h-[220px] items-center justify-center overflow-hidden bg-brand-light">
                <img src={item.image} alt={item.imageAlt} class="h-full w-auto max-w-full object-contain" />
              </div>
              <div class="product-info p-5">
                <h3 class="text-xl font-semibold text-brand-primary">{item.title}</h3>
                <p class="mt-2 text-sm text-slate-700">{item.description}</p>
                <div class="product-price mt-3 font-bold text-brand-accent">{item.price}</div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-white py-6 md:hidden">
    <div class="mx-auto w-full max-w-6xl rounded-lg border border-brand-primary/15 p-4 text-center shadow-sm">
      <h2 class="text-xl font-semibold text-brand-primary">{mobileHighlight.title}</h2>
      <p class="mt-2 text-sm text-slate-700">{mobileHighlight.description}</p>
      <img
        src={mobileHighlight.image}
        alt={mobileHighlight.imageAlt}
        class="mx-auto mt-4 w-full max-w-[260px] rounded-md"
      />
    </div>
  </section>

  <section id="testimonials" class="testimonials bg-brand-secondary py-20">
    <div class="mx-auto w-full max-w-6xl px-5">
      <div class="section-header mx-auto mb-12 max-w-3xl text-center">
        <h2 class="text-3xl font-bold text-brand-primary">{testimonials.title}</h2>
        <p class="text-[15px] text-slate-700">{testimonials.description}</p>
      </div>
      <div class="testimonials-grid grid gap-8 md:grid-cols-2 lg:grid-cols-3">
        {testimonials.items.map((item) => (
          <div>
            <div class="testimonial-card h-full rounded-lg bg-white p-8 shadow-lg">
              <p class="testimonial-text text-sm italic text-slate-700">{item.text}</p>
              <div class="testimonial-author mt-6 flex items-center gap-4">
                <div class="author-avatar h-10 w-10 rounded-full bg-brand-light"></div>
                <div class="author-info">
                  <h4 class="font-semibold text-brand-primary">{item.author}</h4>
                  <p class="text-sm text-slate-600">{item.role}</p>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section id="subscribe" class="cta-section bg-brand-primary py-20 text-center text-white">
    <div class="mx-auto w-full max-w-6xl px-5">
      <h2 class="text-3xl font-bold">{subscribe.title}</h2>
      <p class="mx-auto mt-3 max-w-2xl text-sm text-slate-100">{subscribe.description}</p>
      <a
        href={subscribe.button.href}
        class="mt-6 inline-block rounded-md border border-white/20 bg-brand-primary px-6 py-3 text-sm font-semibold text-white shadow transition-all hover:translate-y-[-1px] hover:bg-brand-accent"
        >{subscribe.button.label}</a
      >
    </div>
  </section>
  <a
    href={stickyCta.href}
    class="mobile-sticky-cta fixed bottom-4 left-1/2 z-[1100] -translate-x-1/2 rounded-full bg-brand-primary px-5 py-3 text-sm font-semibold text-white shadow-xl md:hidden"
    >{stickyCta.label}</a
  >

  <div class="group fixed bottom-[440px] right-3 z-[1150] translate-y-6 opacity-0 [animation:mascot-enter_0.8s_ease_2s_forwards] md:bottom-[18px] md:right-4">
    <img src={mascot.image} alt={mascot.imageAlt} class="h-auto w-[150px] [animation:mascot-bounce_2.4s_ease-in-out_2.8s_infinite] md:w-[340px]" />
    <p class="pointer-events-none absolute bottom-2 right-[120px] min-w-[150px] max-w-[190px] translate-y-2 rounded-lg border border-brand-primary/20 bg-white p-2.5 text-[0.78rem] leading-snug text-[#333333] opacity-0 shadow-lg transition-all duration-200 group-hover:translate-y-0 group-hover:opacity-100 md:bottom-[10px] md:right-[250px] md:min-w-[180px] md:max-w-[240px] md:text-[0.82rem]">
      {mascot.message}
    </p>
  </div>

  <footer class="bg-brand-primary py-10 text-white">
    <div class="mx-auto w-full max-w-6xl px-5">
      <div class="footer-content mb-8">
        <div class="footer-section max-w-2xl">
          <h3 class="text-xl font-semibold">{footer.brand}</h3>
          <p class="mt-3 text-sm text-slate-100">{footer.description}</p>
          <div class="social-links mt-4 flex gap-4 text-sm font-semibold uppercase tracking-wide">
            {footer.socialLinks.map((link) => (
              <a href={link.href} class="transition hover:text-brand-accent">{link.label}</a>
            ))}
          </div>
        </div>
      </div>
      <div class="footer-bottom border-t border-white/15 pt-4 text-center text-xs text-slate-200">
        <p set:html={footer.copyright}></p>
      </div>
    </div>
  </footer>
</Layout>
